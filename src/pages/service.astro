---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';

import project23 from '@assets/images/projects/project-23.jpg';
import project41 from '@assets/images/projects/project-41.jpg';
import project42 from '@assets/images/projects/project-42.jpg';
import project43 from '@assets/images/projects/project-43.jpg';
---

<BaseLayout
  title="Servizi | DEAL Costruzioni Srl"
  description="Servizi di DEAL Costruzioni Srl: edilizia civile, edilizia industriale, restauro e conservazione, reti e sottoservizi. Lavori edili professionali a Trieste e in Friuli Venezia Giulia."
  includeHoverEffect={true}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Servizi", url: "/service" }
  ]}
>

  <!-- page-title-area start -->
  <section class="page-title-area">
    <div class="container rr-container-1650">
      <div class="page-title-area-inner">
        <div class="page-title-wrapper">
          <h2 class="page-sub-title">Servizi</h2>
          <h2 class="page-title">Professionalità e competenza <br />
            al servizio dei vostri progetti</h2>
        </div>
      </div>
    </div>
  </section>
  <!-- page-title-area end -->

  <!-- work-6 area start -->
  <section class="work-6 section-spacing-top-140">
    <div class="container rr-container-1790">
      <div class="work-6__inner">
        <div class="section-title-6__wrapper">
          <h2 class="title rr_title_anim">Le nostre aree <br /><span>di competenza</span> </h2>
        </div>
        <div class="work-6__wrapper">
          <div class="work-6__item">
            <div class="media">
              <Image src={project23} alt="Edilizia civile" />
            </div>
            <div class="content">
              <span class="number">01</span>
              <div class="text">
                <h3 class="title"> <a href="/servizi/edilizia-civile">
                    Edilizia Civile
                  </a></h3>
                <p class="desc">Costruzione e ristrutturazione di edifici residenziali, condomini e abitazioni private. Dall'avvio dei lavori alla consegna chiavi in mano, garantiamo qualità costruttiva, rispetto dei tempi e attenzione al comfort abitativo per ogni tipo di intervento residenziale.</p>
                <div style="margin-top: 20px;">
                  <a href="/servizi/edilizia-civile" class="rr-btn-primary btn-deal">
                    <span class="text">Scopri di più </span>
                    <i class="fa-regular fa-arrow-right-long"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="work-6__item">
            <div class="media">
              <Image src={project41} alt="Edilizia industriale" />
            </div>
            <div class="content">
              <span class="number">02</span>
              <div class="text">
                <h3 class="title"> <a href="/servizi/edilizia-industriale">
                    Edilizia Industriale
                  </a></h3>
                <p class="desc">Realizzazione di capannoni, stabilimenti produttivi e strutture commerciali. Progettiamo e costruiamo edifici industriali pensati per efficienza, sicurezza e funzionalità operativa, con soluzioni strutturali adatte ad ogni esigenza produttiva.</p>
                <div style="margin-top: 20px;">
                  <a href="/servizi/edilizia-industriale" class="rr-btn-primary btn-deal">
                    <span class="text">Scopri di più </span>
                    <i class="fa-regular fa-arrow-right-long"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <div class="work-6__item">
            <div class="media">
              <Image src={project42} alt="Restauro e conservazione" />
            </div>
            <div class="content">
              <span class="number">03</span>
              <div class="text">
                <h3 class="title"> <a href="/servizi/restauri-conservazioni">
                    Restauri e Conservazioni
                  </a></h3>
                <p class="desc">Interventi di restauro e conservazione su edifici storici e di pregio architettonico. Operiamo nel rispetto delle normative vigenti e delle tecniche tradizionali, valorizzando il patrimonio edilizio esistente con competenza e sensibilità.</p>
                <div style="margin-top: 20px;">
                  <a href="/servizi/restauri-conservazioni" class="rr-btn-primary btn-deal">
                    <span class="text">Scopri di più </span>
                    <i class="fa-regular fa-arrow-right-long"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="work-6__item">
            <div class="media">
              <Image src={project43} alt="Reti e sottoservizi" />
            </div>
            <div class="content">
              <span class="number">04</span>
              <div class="text">
                <h3 class="title"> <a href="/servizi/reti-sottoservizi">
                    Reti e Sottoservizi
                  </a></h3>
                <p class="desc">Realizzazione e posa di reti idriche, fognarie, elettriche e di telecomunicazione. Costruiamo infrastrutture sotterranee per contesti urbani e industriali, con tecnologie moderne e nel pieno rispetto delle normative ambientali.</p>
                <div style="margin-top: 20px;">
                  <a href="/servizi/reti-sottoservizi" class="rr-btn-primary btn-deal">
                    <span class="text">Scopri di più </span>
                    <i class="fa-regular fa-arrow-right-long"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- work-6 area end -->

</BaseLayout>

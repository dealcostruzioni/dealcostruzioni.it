---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.astro';

import project17 from '@assets/images/projects/project-17.jpg';
import project18 from '@assets/images/projects/project-18.jpg';
import about6 from '@assets/images/about/about-6.jpg';
import about7 from '@assets/images/about/about-7.jpg';
import about8 from '@assets/images/about/about-8.jpg';
import gallery41 from '@assets/images/gallery/gallery-41.jpg';
import gallery93 from '@assets/images/gallery/gallery-93.jpg';
import gallery94 from '@assets/images/gallery/gallery-94.jpg';
import sottoservizi from '@assets/images/servizi/sottoservizi.jpg';
import gallery48 from '@assets/images/gallery/gallery-48.jpg';
import areaNauticaIntro from '@assets/images/projects/area-nautica-costiera/area-nautica-intro.jpg';
import coperturaIntro from '@assets/images/projects/rifacimento-copertura-storico/copertura-intro.jpg';
import shape9 from '@assets/images/shape/shape-9.png';
---

<BaseLayout
  title="DEAL Costruzioni Srl | Impresa Edile a Trieste - Costruzioni e Ristrutturazioni"
  description="DEAL Costruzioni Srl - Impresa edile a Trieste dal 2007. Costruzioni civili e industriali, ristrutturazioni, restauri, reti e sottoservizi in Friuli Venezia Giulia."
  includeHoverEffect={true}
  includeOdometer={true}
  isHomePage={true}
>
  <!-- hero-3 area start -->
  <section class="hero-3">
    <div class="container rr-container-1650">
      <div class="hero-3__inner rr-line-area">
        <div class="row">
          <div class="col-lg-9">
            <div class="hero-3__content">
              <h1 class="title">Costruiamo il futuro</h1>
              <p class="desc">Diamo forma ai vostri spazi</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- hero-3 area end -->

  <!-- featured-project-3 area start -->
  <section class="featured-project-3">
    <div class="featured-project-3__inner">
      <div class="featured-project-3__left">
        <div class="thumb rr-ov-hidden">
          <Image src={project17} data-speed="0.5" alt="Progetto edile DEAL Costruzioni" />
        </div>
        <div class="content">
          <a href="/service" class="rr-underline">
            <span class="text">Scopri di più</span>
            <i class="fa-solid fa-arrow-right"></i>
          </a>
        </div>
      </div>
      <div class="featured-project-3__right">
        <div class="thumb rr-ov-hidden">
          <Image src={project18} data-speed="0.5" alt="Cantiere DEAL Costruzioni" />
        </div>
        <div class="content">
          <h2 class="title">Realizziamo spazi attraverso un sistema collaudato di costruzione e gestione dei lavori di qualità.</h2>
          <p class="desc">Un'estensione del vostro team, con soluzioni su misura pensate per rispondere alle vostre esigenze attraverso la collaborazione.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- featured-project-3 area end -->

  <!-- about-us-4 area start -->
  <section id="about" class="about-us-4">
    <div class="container rr-container-1820">
      <div class="about-us-4__inner rr-line-area">
        <div class="rr-v-lines">
          <div class="rr-line"></div>
          <div class="rr-line"></div>
        </div>
        <div class="about-us-4__wrapper">
          <div class="about-us-4__box">
            <div class="about-us-4__content">
              <div class="section-title-4__wrapper">
                <div>
                  <h2 class="sottotitolo">LA NOSTRA AZIENDA</h2>
                </div>
                <h3 class="title rr_title_anim">DEAL Costruzioni realizza ogni <br /> progetto come un <span>dialogo <br /> unico con il cliente.</span></h3>
              </div>
              <a href="/service" class="rr-btn-primary btn-deal">
                <span class="text">Scopri di più </span>
                <i class="fa-regular fa-arrow-right-long"></i>
              </a>
            </div>
          </div>
          <div class="about-us-4__box">
            <div class="media rr-ov-hidden">
              <Image src={about6} data-speed="0.8" alt="Progetto DEAL Costruzioni" />
            </div>
            <div class="about-us-4__box__wrapper">
              <div class="about-us-4__item">
                <Image src={about7} alt="Sostenibilità in edilizia" />
                <h3 class="title">Sostenibilità.</h3>
                <p class="desc">Adottiamo soluzioni costruttive a basso impatto ambientale, privilegiando materiali eco-compatibili e tecniche di risparmio energetico.</p>
              </div>
              <div class="about-us-4__item">
                <Image src={about8} alt="Sicurezza in cantiere" />
                <h3 class="title">Sicurezza.</h3>
                <p class="desc">La sicurezza in cantiere è la nostra priorità assoluta. Ogni progetto segue rigorosi protocolli e le normative più aggiornate del settore.</p>
              </div>
              <div class="about-us-4__item">
                <Image src={about7} alt="Materiali di qualità" />
                <h3 class="title">Materiali di Qualità.</h3>
                <p class="desc">Selezioniamo con cura fornitori e materiali certificati per garantire durabilità, prestazioni e un risultato finale di alto livello.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- about-us-4 area end -->

  <!-- experience-4 area start -->
  <section class="experience-4" style="margin-top: -1px;">
    <div class="experience-4__inner" style="border-top: none;">
      <div class="container rr-container-1820">
        <div class="experience-4-wrapper" style="grid-template-columns: 630px 1fr;">
          <div class="experience-4__box" style="border-right: 1px solid #E9E9E9;">
            <div class="section-title-4__wrapper fade-anim">
              <h2 class="sottotitolo">LE NOSTRE ESPERIENZE</h2>
              <h2 class="title rr_title_anim">Consolidati e qualificati <br /><span>nel settore</span></h2>
            </div>
          </div>
          <div class="experience-4__box" style="border-left: none;">
            <div class="experience-4__content">
              <p class="desc">Insieme, costruiamo spazi radicati nella semplicità, realizzati con cura e passione.</p>
              <div class="experience-4__wrapper">
                <div class="experience-4__item"></div>
                <div class="experience-4__item">
                  <h2 class="title"><span class="odometer" data-count="150">0</span>+</h2>
                  <h3 class="sottotitolo">Progetti realizzati</h3>
                </div>
                <div class="experience-4__item">
                  <h2 class="title"><span class="odometer" data-count="20">0</span>+</h2>
                  <h3 class="sottotitolo">Anni esperienza</h3>
                </div>
                <div class="experience-4__item"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- experience-4 area end -->

  <!-- service-4 area start -->
  <section class="service-4 section-spacing-bottom" style="margin-top: 120px;">
    <div class="container rr-container-1820">
      <div class="section-title-4__wrapper">
        <div class="title-wrap fade-anim">
          <h2 class="sottotitolo">I NOSTRI SERVIZI</h2>
          <h2 class="title">Le nostre aree <span>di <br />competenza</span></h2>
        </div>
      </div>
      <div class="service-4__inner">
        <div class="service-4__item">
          <div class="media">
            <div class="thumb">
              <Image src={gallery41} alt="Edilizia civile Trieste" />
            </div>
            <div class="content">
              <h3 class="title"><a href="/servizi/edilizia-civile">Residenze. Condomini. Abitazioni.</a></h3>
              <a class="arrow" href="/servizi/edilizia-civile"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M1 35L18 18L35 1M35 1H13.3636M35 1V22.6364" stroke="#111111" stroke-width="1.4" /></svg></a>
              <p class="desc">Costruzione e ristrutturazione di edifici residenziali, condomini e abitazioni private con attenzione alla qualità e al comfort abitativo.</p>
            </div>
          </div>
          <div class="icon"><i class="fa-solid fa-plus-large"></i></div>
          <h2 class="title">Edilizia Civile</h2>
        </div>
        <div class="service-4__item">
          <div class="media">
            <div class="thumb">
              <Image src={gallery93} alt="Edilizia industriale Trieste" />
            </div>
            <div class="content">
              <h3 class="title"><a href="/servizi/edilizia-industriale">Capannoni. Stabilimenti. Infrastrutture.</a></h3>
              <a class="arrow" href="/servizi/edilizia-industriale"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M1 35L18 18L35 1M35 1H13.3636M35 1V22.6364" stroke="#111111" stroke-width="1.4" /></svg></a>
              <p class="desc">Realizzazione di edifici industriali, capannoni e strutture commerciali progettati per efficienza, sicurezza e funzionalità operativa.</p>
            </div>
          </div>
          <div class="icon"><i class="fa-solid fa-plus-large"></i></div>
          <h2 class="title">Edilizia Industriale</h2>
        </div>
        <div class="service-4__item">
          <div class="media">
            <div class="thumb">
              <Image src={gallery94} alt="Restauri e conservazioni Trieste" />
            </div>
            <div class="content">
              <h3 class="title"><a href="/servizi/restauri-conservazioni">Restauro. Recupero. Valorizzazione.</a></h3>
              <a class="arrow" href="/servizi/restauri-conservazioni"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M1 35L18 18L35 1M35 1H13.3636M35 1V22.6364" stroke="#111111" stroke-width="1.4" /></svg></a>
              <p class="desc">Interventi di restauro e conservazione su edifici storici e di pregio, nel rispetto delle normative e delle tecniche tradizionali.</p>
            </div>
          </div>
          <div class="icon"><i class="fa-solid fa-plus-large"></i></div>
          <h2 class="title">Restauri <span>e</span> Conservazioni</h2>
        </div>
        <div class="service-4__item">
          <div class="media">
            <div class="thumb">
              <Image src={sottoservizi} alt="Reti e sottoservizi Trieste" />
            </div>
            <div class="content">
              <h3 class="title"><a href="/servizi/reti-sottoservizi">Acquedotti. Fognature. Reti tecnologiche.</a></h3>
              <a class="arrow" href="/servizi/reti-sottoservizi"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M1 35L18 18L35 1M35 1H13.3636M35 1V22.6364" stroke="#111111" stroke-width="1.4" /></svg></a>
              <p class="desc">Realizzazione e posa di reti idriche, fognarie, elettriche e di telecomunicazione per infrastrutture urbane e industriali.</p>
            </div>
          </div>
          <div class="icon"><i class="fa-solid fa-plus-large"></i></div>
          <h2 class="title">Reti <span>e</span> Sottoservizi</h2>
        </div>
      </div>
    </div>
  </section>
  <!-- service-4 area end -->

  <!-- call-to-action area start -->
  <section class="call-to-action">
    <div class="call-to-action__inner rr-ov-hidden">
      <div class="media rr-ov-hidden" data-speed="0.7">
        <Image src={gallery48} alt="Cantiere DEAL Costruzioni" />
      </div>
      <div class="section-title-4__wrapper">
        <h2 class="title rr_title_anim">COSTRUIAMO SPAZI DAL 2007 PER <br />OGNI ESIGENZA</h2>
      </div>
    </div>
  </section>
  <!-- call-to-action area end -->

  <!-- our-work-7 area start -->
  <section class="our-work-7 section-spacing-140">
    <div class="container rr-container-1790">
      <div class="section-title-4__wrapper" style="margin-bottom: 60px;">
        <div class="title-wrap fade-anim">
          <h2 class="sottotitolo">IL NOSTRO PORTFOLIO</h2>
          <h2 class="title">I nostri migliori <span>progetti <br />recenti</span></h2>
        </div>
      </div>
      <div class="our-work-7__wrapper">
        <div class="our-work-7__wrap-one">
          <div class="our-work-7__item">
            <div class="our-work-7__thumb rr--hover-item rr-pos-rel">
              <a href="/progetti/portfolio-area-nautica-costiera">
                <div class="rr--hover-img" data-displacement="/images/1.jpg" data-intensity="0.6" data-speedin="1" data-speedout="1">
                  <Image src={areaNauticaIntro} alt="Riqualificazione area nautica costiera" />
                </div>
              </a>
              <div class="project-hover-bar">
                <h3 class="title"><a href="/progetti/portfolio-area-nautica-costiera">Area Nautica Costiera</a></h3>
                <a class="details-link" href="/progetti/portfolio-area-nautica-costiera">Dettagli +</a>
              </div>
            </div>
          </div>
          <div class="our-work-7__item">
            <div class="our-work-7__thumb rr--hover-item rr-pos-rel">
              <a href="/progetti/portfolio-rifacimento-copertura">
                <div class="rr--hover-img" data-displacement="/images/1.jpg" data-intensity="0.6" data-speedin="1" data-speedout="1">
                  <Image src={coperturaIntro} alt="Rifacimento copertura edificio storico" />
                </div>
              </a>
              <div class="project-hover-bar">
                <h3 class="title"><a href="/progetti/portfolio-rifacimento-copertura">Copertura Edificio Storico</a></h3>
                <a class="details-link" href="/progetti/portfolio-rifacimento-copertura">Dettagli +</a>
              </div>
            </div>
          </div>
          <div class="our-work-7__item one">
            <div class="section-title-4__wrapper">
              <div class="title-wrap">
                <h5 class="our-work-7__sub-title">+ I NOSTRI LAVORI</h5>
                <h6 class="title">Scopri tutti i <span>nostri progetti</span></h6>
              </div>
              <div class="our-work-7__btn">
                <a href="/case-studies" class="rr-btn-primary btn-black">
                  <span class="text">Case Studies </span>
                  <i class="fa-regular fa-arrow-right"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- our-work area end -->

  <hr />

  <!-- contact area start -->
  <section class="award-4 section-spacing-top rr-pos-rel" style="z-index: 1; overflow: hidden;">
    <div class="shape" style="position: absolute; bottom: 0; left: 0; z-index: -1;">
      <Image src={shape9} alt="shape decorativo" />
    </div>
    <div class="container rr-container-1820">
      <div class="award-4__inner">
        <div class="section-title-4__wrapper">
          <div class="title-wrap fade-anim">
            <h2 class="sottotitolo">CONTATTACI</h2>
            <h2 class="title">Raccontaci il tuo <span>prossimo <br />progetto</span></h2>
          </div>
        </div>
        <div class="award-4__wrapper">
          <div class="media"></div>
          <div class="contact-area-contact-page section-spacing-bottom">
            <div class="container rr-container-1650">
              <div class="contact-area-contact-page-inner">
                <div class="section-content-wrapper fade-anim">
                  <div class="section-content">
                    <div class="contact-mail"></div>
                  </div>
                  <div class="contact-wrap">
                    <ContactForm />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- contact area end -->
</BaseLayout>

---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';

import coperturaHero from '@assets/images/projects/rifacimento-copertura-storico/copertura-hero.jpg';
import copertura01 from '@assets/images/projects/rifacimento-copertura-storico/copertura-01.jpg';
import copertura02 from '@assets/images/projects/rifacimento-copertura-storico/copertura-02.jpg';
import copertura03 from '@assets/images/projects/rifacimento-copertura-storico/copertura-03.jpg';
import copertura04 from '@assets/images/projects/rifacimento-copertura-storico/copertura-04.jpg';
import copertura05 from '@assets/images/projects/rifacimento-copertura-storico/copertura-05.jpg';
import copertura06 from '@assets/images/projects/rifacimento-copertura-storico/copertura-06.jpg';
import copertura07 from '@assets/images/projects/rifacimento-copertura-storico/copertura-07.jpg';
import copertura08 from '@assets/images/projects/rifacimento-copertura-storico/copertura-08.jpg';
---

<BaseLayout
  title="Rifacimento Copertura Edificio Storico — DEAL Costruzioni"
  description="Rifacimento della copertura di edificio storico vincolato — DEAL Costruzioni Srl, Trieste"
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Case Studies", url: "/case-studies" },
    { name: "Rifacimento Copertura", url: "/progetti/portfolio-rifacimento-copertura" }
  ]}
>
  <main>

    <!-- page-title-area start -->
    <section class="page-title-area">
      <div class="container rr-container-1650">
        <div class="page-title-area-inner">
          <div class="page-title-wrapper">
            <h2 class="page-title"> Rifacimento Copertura<br />
              Edificio Storico</h2>
          </div>
        </div>
      </div>
    </section>
    <!-- page-title-area end -->

    <!-- parallax-view start  -->
    <div class="parallax-view">
      <Image src={coperturaHero} data-speed="0.2" alt="Rifacimento copertura edificio storico — vista panoramica sui tetti di Trieste" loading="eager" fetchpriority="high" />
    </div>
    <!-- parallax-view end  -->

    <!-- portfolio-details start  -->
    <section class="portfolio-details">
      <div class="portfolio-details__inner">
        <div class="container rr-container-1650">
          <div class="section-title-wrapper">
            <h3 class="title">Nel cuore del centro storico di Trieste abbiamo eseguito un intervento completo di riqualificazione della copertura di un edificio vincolato dal punto di vista storico-artistico, con la sostituzione degli elementi strutturali ammalorati e la posa di un <span>nuovo pacchetto isolante</span>, nel pieno rispetto della tutela monumentale.</h3>

            <h4 class="sub-title">Informazioni</h4>
          </div>
          <div class="portfolio-details__wrapper">
            <div class="portfolio-details__media rr-ov-hidden">
              <Image src={copertura06} data-speed="0.4" alt="Dettaglio abbaini e nuova copertura edificio storico" loading="lazy" />
            </div>
            <div class="portfolio-details__content">
              <div class="portfolio-details__info">
                <div class="portfolio-details__info-item">
                  <span>Cliente:</span>
                  <h5 class="title">Privato</h5>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Tipologia:</span>
                  <h6 class="title">Restauro e Conservazione</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Anno:</span>
                  <h6 class="title">2023</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Localizzazione:</span>
                  <h6 class="title">Centro storico, Trieste</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Stato:</span>
                  <h6 class="title">Completato</h6>
                </div>
              </div>
              <div class="portfolio-details__overview">
                <h6 class="title">Panoramica</h6>
                <p>L'edificio, sottoposto a vincolo storico-artistico, presentava una copertura gravemente deteriorata che comprometteva la sicurezza e l'integrità dell'immobile. L'intervento richiedeva competenze specialistiche nel restauro e una costante conformità alle prescrizioni della Soprintendenza.</p>
                <p>L'intervento ha previsto la rimozione dell'intera struttura di copertura esistente e la successiva posa di un nuovo pacchetto isolante. Particolare attenzione è stata dedicata alla realizzazione di numerosi abbaini, integrati armoniosamente nella nuova copertura per migliorarne la funzionalità e l'estetica.</p>

                <ul class="list">
                  <li class="title">Lavorazioni Eseguite</li>
                  <li>Rimozione completa della copertura esistente e smaltimento dei materiali deteriorati</li>
                  <li>Sostituzione degli elementi strutturali ammalorati con nuove orditure in legno</li>
                  <li>Posa di pacchetto isolante ad alte prestazioni termiche</li>
                  <li>Realizzazione di abbaini integrati nel profilo della copertura</li>
                  <li>Posa di manto in coppi nel rispetto delle prescrizioni della Soprintendenza</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- portfolio-details end  -->

    <!-- portfolio-gallery start  -->
    <div class="portfolio-gallery">
      <div class="container rr-container-1650">

        <div class="portfolio-gallery__inner">
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={copertura01} data-speed="0.6" alt="Fase iniziale rimozione copertura esistente" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={copertura02} data-speed="0.6" alt="Lavori strutturali sulla copertura" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={copertura03} data-speed="0.6" alt="Posa nuove orditure in legno" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={copertura04} data-speed="0.6" alt="Realizzazione abbaini" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={copertura05} data-speed="0.6" alt="Nuova copertura in fase di completamento" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={copertura07} data-speed="0.6" alt="Dettaglio struttura copertura" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={copertura08} data-speed="0.6" alt="Vista finale della copertura restaurata" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
    <!-- portfolio-gallery end  -->

  </main>
</BaseLayout>

---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';

import rinforzoMuroHero from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-hero.jpg';
import rinforzoMuro01 from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-01.jpg';
import rinforzoMuro02 from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-02.jpg';
import rinforzoMuro03 from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-03.jpg';
import rinforzoMuro04 from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-04.jpg';
import rinforzoMuro05 from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-05.jpg';
---

<BaseLayout
  title="Rinforzo Strutturale Muro in Pietra — DEAL Costruzioni"
  description="Rinforzo strutturale di un muro di sostegno in pietra — DEAL Costruzioni Srl, Trieste"
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Case Studies", url: "/case-studies" },
    { name: "Rinforzo Muro in Pietra", url: "/progetti/portfolio-rinforzo-muro-pietra" }
  ]}
>
  <main>

    <!-- page-title-area start -->
    <section class="page-title-area">
      <div class="container rr-container-1650">
        <div class="page-title-area-inner">
          <div class="page-title-wrapper">
            <h2 class="page-title"> Rinforzo Strutturale <br />
              Muro di Sostegno in Pietra</h2>
          </div>
        </div>
      </div>
    </section>
    <!-- page-title-area end -->

    <!-- parallax-view start  -->
    <div class="parallax-view">
      <Image src={rinforzoMuroHero} data-speed="0.2" alt="Muro di sostegno in pietra consolidato con tiranti di ancoraggio" />
    </div>
    <!-- parallax-view end  -->

    <!-- portfolio-details start  -->
    <section class="portfolio-details">
      <div class="portfolio-details__inner">
        <div class="container rr-container-1650">
          <div class="section-title-wrapper">
            <h3 class="title">In un contesto condominiale a Trieste siamo stati incaricati di eseguire un intervento di messa in sicurezza e consolidamento di un muro di sostegno in pietra, parzialmente crollato a causa di <span>cedimenti del terreno e degrado strutturale</span>, garantendo stabilità duratura mediante l'installazione di tiranti di ancoraggio.</h3>

            <h4 class="sub-title">Informazioni</h4>
          </div>
          <div class="portfolio-details__wrapper">
            <div class="portfolio-details__media rr-ov-hidden">
              <Image src={rinforzoMuro05} data-speed="0.4" alt="Dettaglio lavori di consolidamento muro in pietra" />
            </div>
            <div class="portfolio-details__content">
              <div class="portfolio-details__info">
                <div class="portfolio-details__info-item">
                  <span>Cliente:</span>
                  <h5 class="title">Privato</h5>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Tipologia:</span>
                  <h6 class="title">Consolidamento Strutturale</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Anno:</span>
                  <h6 class="title">2023</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Localizzazione:</span>
                  <h6 class="title">Trieste</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Stato:</span>
                  <h6 class="title">Completato</h6>
                </div>
              </div>
              <div class="portfolio-details__overview">
                <h6 class="title">Panoramica</h6>
                <p>Il muro di sostegno in pietra presentava un parziale cedimento strutturale dovuto alla combinazione di spinte del terreno, infiltrazioni d'acqua e degrado dei materiali originari. L'intervento richiedeva una soluzione che garantisse la stabilità dell'opera nel tempo, rispettando al contempo le caratteristiche costruttive del manufatto esistente.</p>
                <p>Dopo una prima fase di pulizia e rimozione delle parti instabili, è stata effettuata la ricostruzione del paramento murario con materiali compatibili e tecniche tradizionali. Per garantire la stabilità dell'opera nel tempo, si è poi proceduto con l'installazione di tiranti di ancoraggio, assicurando un'efficace resistenza alle spinte del terreno e un consolidamento duraturo dell'intero sistema.</p>

                <ul class="list">
                  <li class="title">Lavorazioni Eseguite</li>
                  <li>Messa in sicurezza dell'area e rimozione delle parti instabili del muro</li>
                  <li>Ricostruzione del paramento murario con materiali compatibili</li>
                  <li>Installazione di tiranti di ancoraggio per il consolidamento strutturale</li>
                  <li>Iniezioni e rinzaffi per il ripristino della continuità muraria</li>
                  <li>Opere di drenaggio e regimazione delle acque per prevenire futuri cedimenti</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- portfolio-details end  -->

    <!-- portfolio-gallery start  -->
    <div class="portfolio-gallery">
      <div class="container rr-container-1650">

        <div class="portfolio-gallery__inner">
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={rinforzoMuro01} data-speed="0.6" alt="Stato iniziale del muro parzialmente crollato" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={rinforzoMuro02} data-speed="0.6" alt="Fase di ricostruzione del paramento murario" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={rinforzoMuro03} data-speed="0.6" alt="Installazione tiranti di ancoraggio" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={rinforzoMuro04} data-speed="0.6" alt="Dettaglio strumentazione per il tensionamento dei tiranti" />
          </div>
        </div>
      </div>
    </div>
    <!-- portfolio-gallery end  -->

  </main>
</BaseLayout>

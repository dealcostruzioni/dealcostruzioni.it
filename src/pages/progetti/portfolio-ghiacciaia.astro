---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';

import ghiacciaiaHero from '@assets/images/projects/ghiacciaia/ghiacciaia-hero.jpg';
import ghiacciaia01 from '@assets/images/projects/ghiacciaia/ghiacciaia-01.jpg';
import ghiacciaia02 from '@assets/images/projects/ghiacciaia/ghiacciaia-02.jpg';
import ghiacciaia03 from '@assets/images/projects/ghiacciaia/ghiacciaia-03.jpg';
import ghiacciaia04 from '@assets/images/projects/ghiacciaia/ghiacciaia-04.jpg';
import ghiacciaia05 from '@assets/images/projects/ghiacciaia/ghiacciaia-05.jpg';
import ghiacciaia06 from '@assets/images/projects/ghiacciaia/ghiacciaia-06.jpg';
import ghiacciaia07 from '@assets/images/projects/ghiacciaia/ghiacciaia-07.jpg';
---

<BaseLayout
  title="Manutenzione e Recupero della Ghiacciaia — DEAL Costruzioni"
  description="Manutenzione e recupero della ghiacciaia storica (jazera) a Draga Sant'Elia — DEAL Costruzioni Srl, Trieste"
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Case Studies", url: "/case-studies" },
    { name: "Ghiacciaia Storica", url: "/progetti/portfolio-ghiacciaia" }
  ]}
>
  <main>

    <!-- page-title-area start -->
    <section class="page-title-area">
      <div class="container rr-container-1650">
        <div class="page-title-area-inner">
          <div class="page-title-wrapper">
            <h2 class="page-title"> Manutenzione e Recupero <br />
              della Ghiacciaia</h2>
          </div>
        </div>
      </div>
    </section>
    <!-- page-title-area end -->

    <!-- parallax-view start  -->
    <div class="parallax-view">
      <Image src={ghiacciaiaHero} data-speed="0.2" alt="Ghiacciaia storica restaurata a Draga Sant'Elia nel Carso triestino" loading="eager" fetchpriority="high" />
    </div>
    <!-- parallax-view end  -->

    <!-- portfolio-details start  -->
    <section class="portfolio-details">
      <div class="portfolio-details__inner">
        <div class="container rr-container-1650">
          <div class="section-title-wrapper">
            <h3 class="title">L'intervento ha interessato una ghiacciaia storica (jazera) situata a Draga Sant'Elia, significativa testimonianza dell'antico sistema di <span>produzione e conservazione del ghiaccio</span> nel territorio carsico triestino, eseguito nel pieno rispetto delle tecniche costruttive originarie e della tutela ambientale e paesaggistica.</h3>

            <h4 class="sub-title">Informazioni</h4>
          </div>
          <div class="portfolio-details__wrapper">
            <div class="portfolio-details__media rr-ov-hidden">
              <Image src={ghiacciaia06} data-speed="0.4" alt="Lavori di consolidamento murature ghiacciaia" loading="lazy" />
            </div>
            <div class="portfolio-details__content">
              <div class="portfolio-details__info">
                <div class="portfolio-details__info-item">
                  <span>Cliente:</span>
                  <h5 class="title">Pubblico</h5>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Tipologia:</span>
                  <h6 class="title">Restauro e Conservazione</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Anno:</span>
                  <h6 class="title">2021</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Localizzazione:</span>
                  <h6 class="title">Draga Sant'Elia, Carso Triestino</h6>
                </div>
                <div class="portfolio-details__info-item">
                  <span>Stato:</span>
                  <h6 class="title">Completato</h6>
                </div>
              </div>
              <div class="portfolio-details__overview">
                <h6 class="title">Panoramica</h6>
                <p>La ghiacciaia storica, testimonianza unica delle antiche pratiche di conservazione del ghiaccio nel Carso triestino, presentava significativi segni di degrado strutturale e necessitava di un intervento di consolidamento e ripristino che ne garantisse la conservazione e la fruibilità.</p>
                <p>Le opere hanno compreso il consolidamento delle murature e il ripristino delle parti ammalorate, eseguiti con tecniche e materiali compatibili con le costruzioni originarie. Le lavorazioni sono state svolte con particolare attenzione alla conservazione dei materiali esistenti e all'inserimento dell'intervento nel contesto naturale circostante.</p>

                <ul class="list">
                  <li class="title">Lavorazioni Eseguite</li>
                  <li>Consolidamento delle murature in pietra della ghiacciaia con tecniche tradizionali</li>
                  <li>Ripristino delle parti ammalorate con materiali compatibili</li>
                  <li>Messa in sicurezza del sito e dell'area circostante</li>
                  <li>Opere di sistemazione ambientale per la fruibilità pubblica</li>
                  <li>Interventi nel rispetto delle prescrizioni di tutela paesaggistica</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- portfolio-details end  -->

    <!-- portfolio-gallery start  -->
    <div class="portfolio-gallery">
      <div class="container rr-container-1650">

        <div class="portfolio-gallery__inner">
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={ghiacciaia01} data-speed="0.6" alt="Stato iniziale della ghiacciaia prima dell'intervento" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={ghiacciaia02} data-speed="0.6" alt="Fase di consolidamento delle murature in pietra" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={ghiacciaia03} data-speed="0.6" alt="Lavori di ripristino strutturale" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={ghiacciaia04} data-speed="0.6" alt="Dettaglio ricostruzione murature con tecniche tradizionali" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden span-2">
            <Image src={ghiacciaia05} data-speed="0.6" alt="Proseguimento lavori di restauro" loading="lazy" />
          </div>
          <div class="portfolio-gallery__item rr-ov-hidden">
            <Image src={ghiacciaia07} data-speed="0.6" alt="Ghiacciaia completata vista dal sentiero" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
    <!-- portfolio-gallery end  -->

  </main>
</BaseLayout>

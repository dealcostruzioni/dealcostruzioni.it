---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';

import areaNauticaIntro from '@assets/images/projects/area-nautica-costiera/area-nautica-intro.jpg';
import coperturaIntro from '@assets/images/projects/rifacimento-copertura-storico/copertura-intro.jpg';
import ghiacciaiaIntro from '@assets/images/projects/ghiacciaia/ghiacciaia-intro.jpg';
import rinforzoMuroIntro from '@assets/images/projects/rinforzo-muro-pietra/rinforzo-muro-intro.jpg';
---

<BaseLayout
  title="Case Studies | DEAL Costruzioni Srl"
  description="Progetti realizzati da DEAL Costruzioni Srl: ristrutturazioni, restauri, opere strutturali e riqualificazioni a Trieste e in Friuli Venezia Giulia."
  includeHoverEffect={true}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Case Studies", url: "/case-studies" }
  ]}
>
  <main>
    <!-- page-title-area start -->
    <section class="page-title-area">
      <div class="container rr-container-1650">
        <div class="page-title-area-inner">
          <div class="page-title-wrapper">
            <h2 class="page-sub-title"> Case Studies</h2>
            <h2 class="page-title"> Ogni progetto racconta <br />
              la nostra esperienza sul campo</h2>
          </div>
        </div>
      </div>
    </section>
    <!-- page-title-area end -->

    <!-- our-work-7 area start -->
    <section class="our-work-7 section-spacing-140">
      <div class="container rr-container-1790">
        <div class="our-work-7__wrapper">
          <!-- Row 1: 2 projects + intro text -->
          <div class="our-work-7__wrap-one">
            <div class="our-work-7__item">
              <div class="our-work-7__thumb rr--hover-item rr-pos-rel">
                <a href="/progetti/portfolio-area-nautica-costiera">
                  <div class="rr--hover-img" data-displacement="/images/1.jpg"
                    data-intensity="0.6" data-speedin="1" data-speedout="1">
                    <Image src={areaNauticaIntro} alt="Riqualificazione area nautica costiera" />
                  </div>
                </a>
                <div class="project-hover-bar">
                  <h3 class="title"><a href="/progetti/portfolio-area-nautica-costiera">Area Nautica Costiera</a></h3>
                  <a class="details-link" href="/progetti/portfolio-area-nautica-costiera">Dettagli +</a>
                </div>
              </div>
            </div>
            <div class="our-work-7__item">
              <div class="our-work-7__thumb rr--hover-item rr-pos-rel">
                <a href="/progetti/portfolio-rifacimento-copertura">
                  <div class="rr--hover-img" data-displacement="/images/1.jpg"
                    data-intensity="0.6" data-speedin="1" data-speedout="1">
                    <Image src={coperturaIntro} alt="Rifacimento copertura edificio storico" />
                  </div>
                </a>
                <div class="project-hover-bar">
                  <h3 class="title"><a href="/progetti/portfolio-rifacimento-copertura">Copertura Edificio Storico</a></h3>
                  <a class="details-link" href="/progetti/portfolio-rifacimento-copertura">Dettagli +</a>
                </div>
              </div>
            </div>
            <div class="our-work-7__item one">
              <div class="section-title-4__wrapper">
                <div class="title-wrap">
                  <h5 class="our-work-7__sub-title">+ I Nostri LAVORI</h5>
                  <h6 class="title ">I nostri migliori <span>progetti recenti</span>
                  </h6>
                </div>
                <div class="our-work-7__btn">
                  <a href="/contact" class="rr-btn-primary btn-black">
                    <span class="text">Contattaci </span>
                    <i class="fa-regular fa-arrow-right"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Row 2: 3 projects -->
          <div class="our-work-7__wrap-one">
            <div class="our-work-7__item">
              <div class="our-work-7__thumb rr--hover-item rr-pos-rel">
                <a href="/progetti/portfolio-ghiacciaia">
                  <div class="rr--hover-img" data-displacement="/images/1.jpg"
                    data-intensity="0.6" data-speedin="1" data-speedout="1">
                    <Image src={ghiacciaiaIntro} alt="Manutenzione e recupero della ghiacciaia storica" />
                  </div>
                </a>
                <div class="project-hover-bar">
                  <h3 class="title"><a href="/progetti/portfolio-ghiacciaia">Recupero della Ghiacciaia</a></h3>
                  <a class="details-link" href="/progetti/portfolio-ghiacciaia">Dettagli +</a>
                </div>
              </div>
            </div>
            <div class="our-work-7__item">
              <div class="our-work-7__thumb rr--hover-item rr-pos-rel">
                <a href="/progetti/portfolio-rinforzo-muro-pietra">
                  <div class="rr--hover-img" data-displacement="/images/1.jpg"
                    data-intensity="0.6" data-speedin="1" data-speedout="1">
                    <Image src={rinforzoMuroIntro} alt="Rinforzo strutturale muro di sostegno in pietra" />
                  </div>
                </a>
                <div class="project-hover-bar">
                  <h3 class="title"><a href="/progetti/portfolio-rinforzo-muro-pietra">Muro di Sostegno in Pietra</a></h3>
                  <a class="details-link" href="/progetti/portfolio-rinforzo-muro-pietra">Dettagli +</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- our-work area end -->
  </main>
</BaseLayout>

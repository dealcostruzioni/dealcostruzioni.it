---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Pagina Non Trovata | DEAL Costruzioni Srl"
  description="Pagina non trovata - DEAL Costruzioni Srl"
  noindex={true}
>
  <main>
    <!-- 404 area start -->
    <section class="page-title-area">
      <div class="container rr-container-1650">
        <div class="page-title-area-inner" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
          <div style="margin-bottom: 50px;">
            <!-- SVG: Construction helmet / hard hat -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 180" width="200" height="180" aria-label="Illustrazione casco da cantiere">
              <g fill="none" stroke-linecap="round" stroke-linejoin="round">
                <!-- Hard hat dome -->
                <path d="M40 110 C40 55, 160 55, 160 110" stroke="#3E5A5D" stroke-width="3" fill="#3E5A5D" opacity="0.1"></path>
                <path d="M40 110 C40 55, 160 55, 160 110" stroke="#3E5A5D" stroke-width="3" fill="none"></path>
                <!-- Hat brim -->
                <path d="M25 110 L175 110" stroke="#3E5A5D" stroke-width="4"></path>
                <rect x="25" y="110" width="150" height="12" rx="3" fill="#3E5A5D" opacity="0.15" stroke="#3E5A5D" stroke-width="2"></rect>
                <!-- Hat front detail -->
                <path d="M80 80 L120 80" stroke="#D4A853" stroke-width="3"></path>
                <path d="M75 90 L125 90" stroke="#D4A853" stroke-width="2" opacity="0.6"></path>
                <!-- Construction crane (background) -->
                <line x1="160" y1="30" x2="160" y2="105" stroke="#3E5A5D" stroke-width="1.5" opacity="0.3"></line>
                <line x1="160" y1="30" x2="190" y2="30" stroke="#3E5A5D" stroke-width="1.5" opacity="0.3"></line>
                <line x1="190" y1="30" x2="190" y2="50" stroke="#3E5A5D" stroke-width="1" opacity="0.3"></line>
                <line x1="145" y1="30" x2="160" y2="30" stroke="#3E5A5D" stroke-width="1.5" opacity="0.3"></line>
                <!-- Small building blocks (background) -->
                <rect x="15" y="135" width="18" height="12" rx="1" fill="none" stroke="#3E5A5D" stroke-width="1.5" opacity="0.25"></rect>
                <rect x="33" y="135" width="18" height="12" rx="1" fill="none" stroke="#3E5A5D" stroke-width="1.5" opacity="0.25"></rect>
                <rect x="24" y="123" width="18" height="12" rx="1" fill="none" stroke="#3E5A5D" stroke-width="1.5" opacity="0.25"></rect>
                <!-- Warning triangle -->
                <path d="M100 148 L88 168 L112 168 Z" stroke="#D4A853" stroke-width="2" fill="#D4A853" opacity="0.15"></path>
                <line x1="100" y1="155" x2="100" y2="162" stroke="#D4A853" stroke-width="2"></line>
                <circle cx="100" cy="165" r="1" fill="#D4A853"></circle>
              </g>
            </svg>
          </div>
          <div class="page-title-wrapper" style="text-align: center;">
            <h2 class="page-sub-title">Errore 404</h2>
            <h2 class="page-title">Pagina non <span>trovata</span></h2>
          </div>
          <p style="font-size: 18px; line-height: 28px; color: #555555; max-width: 600px; margin: 40px auto 50px;">La pagina che stai cercando non esiste o è stata spostata. Torna alla homepage per continuare la navigazione.</p>
          <a href="/" class="rr-btn-primary btn-deal">
            <span class="text">Torna alla Home </span>
            <i class="fa-regular fa-arrow-right-long"></i>
          </a>
        </div>
      </div>
    </section>
    <!-- 404 area end -->
  </main>
</BaseLayout>

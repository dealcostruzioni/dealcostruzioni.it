---
import { Image } from 'astro:assets';
import logoImg from '@assets/images/logo/logo.jpg';
---

<footer class="footer-10 custom-footer-theme">
  <div class="footer-10-wrapper">
    <div class="container rr-container-1890">
      <div class="footer-10__inner">
        <div class="footer-widget-wrapper">
          <div class="footer-widget-box">
            <div class="footer-logo" style="margin-bottom: 30px;">
              <Image src={logoImg} alt="DEAL Costruzioni Srl" width={200} />
            </div>
            <div class="copyright-text">
              <p class="text">
                <a href="https://dealcostruzioni.it">© DEAL Costruzioni Srl</a> {new Date().getFullYear()}
              </p>
            </div>
          </div>
          <div class="footer-widget-box">
            <h2 class="title">Sede</h2>
            <div class="footer-location">
              <p>
                Via Norma Cossetto, 4 <br />
                34145 Trieste (TS)<br />
                Italia
              </p>
              <a href="tel:+390402650468">(+39) 040 2650468</a>
              <a href="mailto:info@dealcostruzioni.it">info@dealcostruzioni.it</a>
            </div>
          </div>
          <div class="footer-widget-box">
            <h2 class="title">Social</h2>
            <ul class="footer-nav-list">
              <li><a href="https://www.linkedin.com/" data-text="LinkedIn"><span>LinkedIn</span></a></li>
              <li><a href="https://www.facebook.com/" data-text="Facebook"><span>Facebook</span></a></li>
              <li><a href="https://www.instagram.com/" data-text="Instagram"><span>Instagram</span></a></li>
            </ul>
          </div>
          <div class="footer-widget-box">
            <h2 class="title">Link Rapidi</h2>
            <ul class="footer-nav-list">
              <li><a href="/privacy-policy" data-text="Privacy Policy"><span>Privacy Policy</span></a></li>
              <li><a href="/cookie-policy" data-text="Cookie Policy"><span>Cookie Policy</span></a></li>
              <li><button type="button" onclick="window.__openCookieSettings && window.__openCookieSettings()" class="footer-cookie-btn" aria-label="Gestisci Cookie"><span>Gestisci Cookie</span></button></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

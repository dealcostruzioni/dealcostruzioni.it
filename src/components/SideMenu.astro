---
// Offcanvas side menu — shared across all pages
---

<aside class="fix">
  <div class="side-info">
    <div class="side-info-content">
      <div class="offset-widget offset-header">
        <div class="offset-logo">
          <a href="/">
            <img class="show-light" src="/images/logo/logo.jpg" alt="DEAL Costruzioni Srl" />
          </a>
        </div>
        <button id="side-info-close" class="side-info-close">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="mobile-menu d-xl-none fix"></div>
      <div class="offset-button">
        <a href="/contact" class="rr-btn">
          <span class="btn-wrap">
            <span class="text-one">Parliamo</span>
            <span class="text-two">Parliamo</span>
          </span>
        </a>
      </div>
      <div class="offset-widget-box">
        <h2 class="title">Contattaci</h2>
        <div class="contact-meta">
          <div class="contact-item">
            <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
            <span class="text">Via Norma Cossetto, 4 — 34145 Trieste (TS), Italia</span>
          </div>
          <div class="contact-item">
            <span class="icon"><i class="fa-solid fa-envelope"></i></span>
            <span class="text"><a href="mailto:info@dealcostruzioni.it">info@dealcostruzioni.it</a></span>
          </div>
          <div class="contact-item">
            <span class="icon"><i class="fa-solid fa-phone"></i></span>
            <span class="text"><a href="tel:+390402650468">(+39) 040 2650468</a></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>
<div class="offcanvas-overlay"></div>
